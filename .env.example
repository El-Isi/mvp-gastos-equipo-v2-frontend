# ============================================
# Gastos Equipo v2 — Variables de Entorno
# ============================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- API Backend (GAP: aún no existe, usar mock local) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# --- Auth Service (Konfío real) ---
AUTH_SERVICE_URL=https://auth.konfio.mx/api/v1
AUTH_SERVICE_API_KEY=your-auth-api-key-here

# --- Notification Service (Konfío real) ---
NOTIFICATIONS_URL=https://notifications.konfio.mx/api/v1
NOTIFICATIONS_API_KEY=your-notifications-api-key-here
